# ===========================================
# STEMWORKFORCE PLATFORM - Environment Config
# ===========================================
# Copy this file to .env.local for local development
# Copy to .env.production for production deployment

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_VERSION=v1

# Authentication (Auth0)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_AUDIENCE=https://api.stemworkforce.gov
VITE_AUTH0_CALLBACK_URL=http://localhost:3000/callback

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_AUDIT_LOGGING=true
VITE_ENABLE_MOCK_DATA=true
VITE_ENABLE_DEBUG_MODE=true

# Session Configuration
VITE_SESSION_TIMEOUT_MINUTES=30
VITE_TOKEN_REFRESH_INTERVAL_MINUTES=5

# External Services
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=
VITE_MAPBOX_TOKEN=

# CDN & Assets
VITE_CDN_URL=
VITE_ASSETS_URL=/assets

# Rate Limiting
VITE_API_RATE_LIMIT=100
VITE_SEARCH_DEBOUNCE_MS=300

# Pagination
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100
