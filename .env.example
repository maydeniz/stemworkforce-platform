# ===========================================
# STEMWORKFORCE PLATFORM - Environment Config
# ===========================================
# Copy this file to .env.local for local development
# Copy to .env.production for production deployment

# Supabase Configuration (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_VERSION=v1

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_AUDIT_LOGGING=true
VITE_ENABLE_MOCK_DATA=true
VITE_ENABLE_DEBUG_MODE=false

# Session Configuration
VITE_SESSION_TIMEOUT_MINUTES=30
VITE_TOKEN_REFRESH_INTERVAL_MINUTES=5

# External Services (Optional)
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=
VITE_MAPBOX_TOKEN=

# CDN & Assets
VITE_CDN_URL=
VITE_ASSETS_URL=/assets

# Rate Limiting
VITE_API_RATE_LIMIT=100
VITE_SEARCH_DEBOUNCE_MS=300

# Pagination
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# ===========================================
# SERVER-SIDE API KEYS (Supabase Edge Functions)
# ===========================================
# These are set in Supabase Dashboard > Settings > Edge Functions > Secrets
# They are NEVER exposed to the browser. Do NOT use the VITE_ prefix.
#
# BLS (Bureau of Labor Statistics) OEWS API
# Register at: https://www.bls.gov/developers/home.htm
# Used by: workforce-data-sync edge function
# BLS_API_KEY=your-bls-api-key
#
# USAJOBS Federal Jobs API
# Register at: https://developer.usajobs.gov/APIRequest/Index
# Used by: federation-sync edge function
# USAJOBS_API_KEY=your-usajobs-api-key
# USAJOBS_USER_AGENT=YourEmail@domain.com (required by USAJOBS TOS)
#
# Greenhouse & Lever job board APIs require NO keys (public endpoints).
# Configured companies are in: supabase/migrations/059_greenhouse_lever_federation.sql
#
# Learning Commons Knowledge Graph API
# Register at: https://learningcommons.org (free, CZI-backed)
# Used by: EduFlow AI standards alignment, content evaluators, learning progressions
# Falls back to public JSONL export if not configured.
# LEARNING_COMMONS_API_KEY=your-learning-commons-api-key
#
# Anthropic Claude API (for AI features including content evaluation)
# Register at: https://console.anthropic.com
# Used by: EduFlow AI agents, content evaluators, voice assistant
# ANTHROPIC_API_KEY=your-anthropic-api-key
